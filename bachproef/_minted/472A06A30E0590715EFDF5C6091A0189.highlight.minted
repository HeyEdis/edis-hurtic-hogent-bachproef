\PYG{+w}{    }\PYG{k}{if}\PYG{+w}{ }\PYG{o}{[}\PYG{+w}{ }\PYGZhy{}n\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}USER\PYGZus{}STORY}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{o}{]}\PYG{+w}{ }\PYG{o}{\PYGZam{}\PYGZam{}}\PYG{+w}{ }\PYG{o}{[}\PYG{+w}{ }\PYGZhy{}f\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}USER\PYGZus{}STORY}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{o}{]}\PYG{p}{;}\PYG{+w}{ }\PYG{k}{then}
\PYG{+w}{      }\PYG{n+nv}{CONTEXT}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}@}\PYG{l+s+si}{\PYGZdl{}\PYGZob{}}\PYG{n+nv}{USER\PYGZus{}STORY}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ }\PYG{l+s+si}{\PYGZdl{}\PYGZob{}}\PYG{n+nv}{CONTEXT}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}
\PYG{+w}{    }\PYG{k}{fi}

\PYG{+w}{    }\PYG{k}{if}\PYG{+w}{ }\PYG{o}{[}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}HITL}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nb}{true}\PYG{+w}{ }\PYG{o}{]}\PYG{p}{;}\PYG{+w}{ }\PYG{k}{then}
\PYG{+w}{      }\PYG{c+c1}{\PYGZsh{} Run the task non\PYGZhy{}interactively first}
\PYG{+w}{      }\PYG{n+nv}{result}\PYG{o}{=}\PYG{k}{\PYGZdl{}(}codex\PYG{+w}{ }\PYG{n+nb}{exec}\PYG{+w}{ }\PYG{n+nv}{\PYGZdl{}CODEX\PYGZus{}FLAGS}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}CONTEXT}\PYG{l+s+s2}{ }\PYG{n+nv}{\PYGZdl{}PROMPT}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{p}{|}\PYG{+w}{ }tee\PYG{+w}{ }/dev/stderr\PYG{k}{)}
\PYG{+w}{      }\PYG{c+c1}{\PYGZsh{} Then start interactive session for review}
\PYG{+w}{      }\PYG{n+nb}{echo}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}\PYGZbs{}n=== Task complete. Starting interactive review session ===\PYGZdq{}}
\PYG{+w}{      }\PYG{n+nb}{echo}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}Paste feedback or type \PYGZsq{}done\PYGZsq{} to continue to next task.\PYGZdq{}}
\PYG{+w}{      }codex\PYG{+w}{ }\PYG{n+nv}{\PYGZdl{}CODEX\PYGZus{}FLAGS}
\PYG{+w}{    }\PYG{k}{elif}\PYG{+w}{ }\PYG{o}{[}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}SANDBOX}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nb}{true}\PYG{+w}{ }\PYG{o}{]}\PYG{p}{;}\PYG{+w}{ }\PYG{k}{then}
\PYG{+w}{      }\PYG{n+nv}{result}\PYG{o}{=}\PYG{k}{\PYGZdl{}(}codex\PYG{+w}{ }\PYG{n+nb}{exec}\PYG{+w}{ }\PYGZhy{}\PYGZhy{}sandbox\PYG{+w}{ }danger\PYGZhy{}full\PYGZhy{}access\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}CONTEXT}\PYG{l+s+s2}{ }\PYG{n+nv}{\PYGZdl{}PROMPT}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{p}{|}\PYG{+w}{ }tee\PYG{+w}{ }/dev/stderr\PYG{k}{)}
\PYG{+w}{    }\PYG{k}{else}
\PYG{+w}{      }\PYG{n+nv}{result}\PYG{o}{=}\PYG{k}{\PYGZdl{}(}codex\PYG{+w}{ }\PYG{n+nb}{exec}\PYG{+w}{ }\PYG{n+nv}{\PYGZdl{}CODEX\PYGZus{}FLAGS}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}CONTEXT}\PYG{l+s+s2}{ }\PYG{n+nv}{\PYGZdl{}PROMPT}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{p}{|}\PYG{+w}{ }tee\PYG{+w}{ }/dev/stderr\PYG{k}{)}
\PYG{+w}{    }\PYG{k}{fi}

\PYG{+w}{    }\PYG{k}{if}\PYG{+w}{ }\PYG{o}{[}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}HITL}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }!\PYG{o}{=}\PYG{+w}{ }\PYG{n+nb}{true}\PYG{+w}{ }\PYG{o}{]}\PYG{+w}{ }\PYG{o}{\PYGZam{}\PYGZam{}}\PYG{+w}{ }\PYG{o}{[[}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}result}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{o}{==}\PYG{+w}{ }*\PYG{l+s+s2}{\PYGZdq{}\PYGZlt{}promise\PYGZgt{}COMPLETE\PYGZlt{}/promise\PYGZgt{}\PYGZdq{}}*\PYG{+w}{ }\PYG{o}{]]}\PYG{p}{;}\PYG{+w}{ }\PYG{k}{then}
\PYG{+w}{      }\PYG{n+nb}{echo}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}Plan }\PYG{l+s+si}{\PYGZdl{}\PYGZob{}}\PYG{n+nv}{STORY\PYGZus{}NAME}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ complete!\PYGZdq{}}
\PYG{+w}{      }\PYG{k}{break}
