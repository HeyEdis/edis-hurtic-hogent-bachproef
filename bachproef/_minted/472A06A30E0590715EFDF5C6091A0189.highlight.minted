\PYG{+w}{  }\PYG{k}{if}\PYG{+w}{ }\PYG{o}{[}\PYG{+w}{ }\PYG{l+s+si}{\PYGZdl{}\PYGZob{}\PYGZsh{}}\PYG{n+nv}{PLAN\PYGZus{}FILES}\PYG{p}{[@]}\PYG{l+s+si}{\PYGZcb{}}\PYG{+w}{ }\PYGZhy{}eq\PYG{+w}{ }\PYG{l+m}{0}\PYG{+w}{ }\PYG{o}{]}\PYG{p}{;}\PYG{+w}{ }\PYG{k}{then}
\PYG{+w}{    }\PYG{n+nb}{echo}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}All plans complete! Nothing to do.\PYGZdq{}}
\PYG{+w}{    }\PYG{n+nb}{exit}\PYG{+w}{ }\PYG{l+m}{0}
\PYG{+w}{  }\PYG{k}{fi}
\PYG{+w}{  }\PYG{n+nb}{echo}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}Found }\PYG{l+s+si}{\PYGZdl{}\PYGZob{}\PYGZsh{}}\PYG{n+nv}{PLAN\PYGZus{}FILES}\PYG{p}{[@]}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ plan(s) with incomplete tasks.\PYGZdq{}}
\PYG{k}{fi}

\PYG{c+c1}{\PYGZsh{} Process each plan}
\PYG{k}{for}\PYG{+w}{ }PLAN\PYG{+w}{ }\PYG{k}{in}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+si}{\PYGZdl{}\PYGZob{}}\PYG{n+nv}{PLAN\PYGZus{}FILES}\PYG{p}{[@]}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{;}\PYG{+w}{ }\PYG{k}{do}
\PYG{+w}{  }\PYG{n+nv}{STORY\PYGZus{}NAME}\PYG{o}{=}\PYG{k}{\PYGZdl{}(}basename\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}PLAN}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }.json\PYG{k}{)}
\PYG{+w}{  }\PYG{n+nv}{PROGRESS}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+si}{\PYGZdl{}\PYGZob{}}\PYG{n+nv}{PLANS\PYGZus{}DIR}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{/}\PYG{l+s+si}{\PYGZdl{}\PYGZob{}}\PYG{n+nv}{STORY\PYGZus{}NAME}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{.progress.md\PYGZdq{}}

\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} Resolve user story path from plan\PYGZsq{}s source.user\PYGZus{}story field}
\PYG{+w}{  }\PYG{n+nv}{USER\PYGZus{}STORY}\PYG{o}{=}\PYG{k}{\PYGZdl{}(}grep\PYG{+w}{ }\PYGZhy{}o\PYG{+w}{ }\PYG{l+s+s1}{\PYGZsq{}\PYGZdq{}user\PYGZus{}story\PYGZdq{}: \PYGZdq{}[\PYGZca{}\PYGZdq{}]*\PYGZdq{}\PYGZsq{}}\PYG{+w}{ }\PYG{l+s+s2}{\PYGZdq{}}\PYG{n+nv}{\PYGZdl{}PLAN}\PYG{l+s+s2}{\PYGZdq{}}\PYG{+w}{ }\PYG{p}{|}\PYG{+w}{ }head\PYG{+w}{ }\PYGZhy{}1\PYG{+w}{ }\PYG{p}{|}\PYG{+w}{ }cut\PYG{+w}{ }\PYGZhy{}d\PYG{l+s+s1}{\PYGZsq{}\PYGZdq{}\PYGZsq{}}\PYG{+w}{ }\PYGZhy{}f4\PYG{k}{)}

