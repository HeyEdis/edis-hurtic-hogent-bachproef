\PYG{k}{\PYGZhy{}}\PYG{+w}{ }\PYG{l+s+sb}{`trace: \PYGZsq{}retain\PYGZhy{}on\PYGZhy{}failure\PYGZhy{}and\PYGZhy{}retries\PYGZsq{}`}
